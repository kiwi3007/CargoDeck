{
  "name": "playerr",
  "version": "0.3.12",
  "description": "Playerr - A PVR for Video Games",
  "scripts": {
    "build": "webpack --config ./frontend/build/webpack.config.js",
    "prebuild": "npm run clean",
    "clean": "rimraf ./_output/UI && rimraf --glob \"**/*.js.map\"",
    "start": "webpack --watch --config ./frontend/build/webpack.config.js",
    "watch": "webpack --watch --config ./frontend/build/webpack.config.js",
    "lint": "eslint --config frontend/.eslintrc.js --ignore-path frontend/.eslintignore frontend/",
    "lint-fix": "npm run lint -- --fix"
  },
  "author": "Team Playerr",
  "license": "MIT",
  "main": "index.ts",
  "browserslist": [
    "defaults"
  ],
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/free-regular-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@microsoft/signalr": "^8.0.7",
    "@tanstack/react-query": "^5.74.3",
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.1",
    "axios": "^1.7.9",
    "classnames": "^2.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "css-loader": "^6.11.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.2",
    "html-webpack-plugin": "^5.6.3",
    "rimraf": "^5.0.10",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.1",
    "typescript": "^5.7.2",
    "webpack": "^5.97.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}